ip addr add 192.168.10.1/24 dev eth0
ip link set eth0 up

ip addr add 192.168.2.1/24 dev eth1
ip link set eth1 up

ip addr add 192.168.11.1/24 dev eth2
ip link set eth2 up

cat <<EOF > /etc/dnsmasq.conf
interface=eth1
dhcp-range=192.168.2.2,192.168.2.254,12h
dhcp-option=3,192.168.2.1   # gateway
dhcp-option=6,8.8.8.8       # DNS
EOF

systemctl restart dnsmasq

ip route add 192.168.1.0/24 via 192.168.10.2
ip route add 192.168.3.0/24 via 192.168.11.2

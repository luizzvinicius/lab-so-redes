ip addr add 192.168.3.1/24 dev eth0
ip link set eth0 up

ip addr add 192.168.11.2/24 dev eth1
ip link set eth1 up

systemctl restart dnsmasq

ip route add 192.168.1.0/24  via 192.168.11.1
ip route add 192.168.2.0/24  via 192.168.11.1
ip route add 192.168.10.0/24 via 192.168.11.1

ip route add default via 192.168.11.1